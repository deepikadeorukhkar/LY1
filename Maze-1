<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Butterfly Garden Maze</title>

<style>
body{
margin:0;
font-family: 'Comic Sans MS', cursive;
background:linear-gradient(#c7f9ff,#e6ffe6);
text-align:center;
overflow:hidden;
}

h1{margin:8px;}

canvas{
background:linear-gradient(#c7f9ff,#f0ffe6);
border-radius:20px;
box-shadow:0 0 15px rgba(0,0,0,0.2);
touch-action:none;
}

button{
margin-top:12px;
padding:12px 28px;
font-size:18px;
border:none;
background:#ff7eb3;
color:white;
border-radius:12px;
cursor:pointer;
}

#message{
height:30px;
font-size:22px;
}
</style>
</head>

<body>

<h1>Help the Butterfly Reach the Flowers</h1>
<div id="message"></div>

<canvas id="maze" width="900" height="500"></canvas>
<br>
<button onclick="restartGame()">Restart</button>

<canvas id="confetti"></canvas>

<audio id="wrong" src="https://cdn.jsdelivr.net/gh/naptha/talkify-tts/examples/audio/fail.mp3"></audio>
<audio id="clap" src="https://cdn.jsdelivr.net/gh/jshawl/AudioFX/sounds/applause.mp3"></audio>

<script>
const canvas=document.getElementById("maze");
const ctx=canvas.getContext("2d");
const message=document.getElementById("message");

let drawing=false;
let finished=false;

let butterfly={x:40,y:260};

const path=[
{x:20,y:240,w:200,h:60},
{x:200,y:150,w:60,h:150},
{x:200,y:150,w:260,h:60},
{x:440,y:150,w:60,h:250},
{x:440,y:340,w:240,h:60},
{x:680,y:240,w:60,h:160},
{x:680,y:240,w:200,h:60}
];

const end={x:760,y:200,w:140,h:200};

function draw(){
ctx.clearRect(0,0,canvas.width,canvas.height);

// sky
let sky=ctx.createLinearGradient(0,0,0,500);
sky.addColorStop(0,"#c7f9ff");
sky.addColorStop(1,"#e6ffe6");
ctx.fillStyle=sky;
ctx.fillRect(0,0,900,500);

// grass
ctx.fillStyle="#b7f7b7";
ctx.fillRect(0,420,900,80);

// decorative flowers
ctx.font="22px serif";
ctx.fillText("🌸 🌼 🌸 🌼",150,70);
ctx.fillText("🌼 🌸 🌼 🌸",500,120);

// maze path
ctx.fillStyle="#ffe066";
path.forEach(p=> ctx.fillRect(p.x,p.y,p.w,p.h));

// flower plant end
ctx.font="90px serif";
ctx.fillText("🌿",760,380);
ctx.font="70px serif";
ctx.fillText("🌸🌼",770,300);

// butterfly (small)
ctx.font="34px serif";
ctx.fillText("🦋",butterfly.x,butterfly.y);
}

draw();

function isOnPath(x,y){
for(let p of path){
if(x>p.x && x<p.x+p.w && y>p.y && y<p.y+p.h){
return true;
}
}
return false;
}

function reachedEnd(x,y){
return x>end.x && x<end.x+end.w && y>end.y && y<end.y+end.h;
}

canvas.addEventListener("pointerdown",()=>drawing=true);
canvas.addEventListener("pointerup",()=>drawing=false);

canvas.addEventListener("pointermove",e=>{
if(!drawing || finished) return;

const rect=canvas.getBoundingClientRect();
const x=e.clientX-rect.left;
const y=e.clientY-rect.top;

if(!isOnPath(x,y)){
wrongMove();
return;
}

// smooth movement
butterfly.x += (x-18 - butterfly.x)*0.35;
butterfly.y += (y+10 - butterfly.y)*0.35;

// sparkle trail
ctx.fillStyle="#ff7eb3";
ctx.beginPath();
ctx.arc(butterfly.x+12,butterfly.y,5,0,Math.PI*2);
ctx.fill();

ctx.font="14px serif";
ctx.fillText("✨",butterfly.x,butterfly.y);

draw();

if(reachedEnd(x,y)) win();
});

function wrongMove(){
drawing=false;
document.getElementById("wrong").play();
message.innerHTML="❌ Try Again";
setTimeout(restartGame,800);
}

function win(){
finished=true;
document.getElementById("clap").play();
message.innerHTML="🎉 Wonderful!";
startConfetti();
}

function restartGame(){
finished=false;
message.innerHTML="";
butterfly={x:40,y:260};
draw();
}

// confetti
const confettiCanvas=document.getElementById("confetti");
const confettiCtx=confettiCanvas.getContext("2d");
confettiCanvas.width=window.innerWidth;
confettiCanvas.height=window.innerHeight;

let pieces=[];

function startConfetti(){
pieces=[];
for(let i=0;i<120;i++){
pieces.push({
x:Math.random()*confettiCanvas.width,
y:Math.random()*-confettiCanvas.height,
r:Math.random()*6+4,
color:`hsl(${Math.random()*360},100%,50%)`
});
}
animateConfetti();
}

function animateConfetti(){
confettiCtx.clearRect(0,0,confettiCanvas.width,confettiCanvas.height);
for(let p of pieces){
confettiCtx.fillStyle=p.color;
confettiCtx.fillRect(p.x,p.y,p.r,p.r);
p.y+=2;
}
requestAnimationFrame(animateConfetti);
}

// voice instruction
window.onload=()=>{
setTimeout(()=>{
const speech=new SpeechSynthesisUtterance("Help the butterfly reach the flowers");
speech.rate=0.85;
speech.pitch=1.2;
speechSynthesis.speak(speech);
},600);
};
</script>

</body>
</html>
